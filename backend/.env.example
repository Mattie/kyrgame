# Copy to backend/.env and load before starting the API.
KYRGAME_ADMIN_TOKEN=dev-admin-token
# Optional: define role/flag scoped tokens instead of the single token above.
# KYRGAME_ADMIN_TOKENS='{"sysop":{"roles":["player_admin","content_admin","message_admin"],"flags":["allow_delete_players","allow_player_rename"]}}'

# Runtime fixture bootstrap controls (safe defaults)
KYRGAME_RESET_ON_BOOT=0
KYRGAME_SEED_IF_EMPTY=1

